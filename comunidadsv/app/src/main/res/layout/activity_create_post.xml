<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0A7A33"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_back"
            app:title="Crear Publicación" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Campo Título -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Título"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edtTitulo"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Escribe un título"
                android:background="@drawable/edittext_style"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:layout_marginBottom="20dp" />

            <!-- Campo Descripción -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edtDescripcion"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Cuenta más detalles"
                android:background="@drawable/edittext_style"
                android:padding="16dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- Contador de caracteres -->
            <TextView
                android:id="@+id/txtContador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0/500"
                android:textSize="12sp"
                android:textColor="#999999"
                android:textAlignment="textEnd"
                android:layout_marginBottom="20dp" />

            <!-- Categoría -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Categoría"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Grid de categorías -->
            <GridLayout
                android:id="@+id/gridCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="4"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/catTrafico"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🚗 Tráfico"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/category_unselected"
                    android:layout_margin="4dp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/catSeguridad"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🛡️ Seguridad"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/category_unselected"
                    android:layout_margin="4dp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/catEmergencia"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🚨 Emergencia"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/category_unselected"
                    android:layout_margin="4dp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/catMascotas"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🐾 Mascotas"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/category_unselected"
                    android:layout_margin="4dp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/catEventos"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🎉 Eventos"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/category_unselected"
                    android:layout_margin="4dp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/catAyuda"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🤝 Ayuda"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/category_unselected"
                    android:layout_margin="4dp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/catObjetos"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="📦 Objetos"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/category_unselected"
                    android:layout_margin="4dp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/catOtros"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="📌 Otros"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/category_unselected"
                    android:layout_margin="4dp"
                    android:padding="8dp" />

            </GridLayout>

            <!-- ESTADO DEL GPS -->
            <TextView
                android:id="@+id/txtEstadoGps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔄 Obteniendo ubicación..."
                android:textSize="12sp"
                android:textColor="#666666"
                android:padding="8dp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- Ubicación -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ubicación"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/edtUbicacion"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Col. San Benito"
                    android:background="@drawable/edittext_style"
                    android:paddingStart="16dp"
                    android:paddingEnd="56dp"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/btnMiUbicacion"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_location"
                    android:tint="#0A7A33" />

            </RelativeLayout>

            <!-- SECCIÓN DE FOTOS - REDISEÑADA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fotos"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Botones para agregar fotos (horizontal) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/btnAgregarFoto"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/button_outline_style"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_add"
                        android:tint="#0A7A33" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Galería"
                        android:textSize="12sp"
                        android:textColor="#0A7A33"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnTomarFoto"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/button_outline_style"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_camera"
                        android:tint="#0A7A33" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cámara"
                        android:textSize="12sp"
                        android:textColor="#0A7A33"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Área de vista previa de fotos (grid de 2 columnas) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vista previa"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFotosPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <!-- Botón Publicar -->
            <Button
                android:id="@+id/btnPublicar"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="PUBLICAR"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0A7A33"
                android:layout_marginBottom="16dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="#0A7A33" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>