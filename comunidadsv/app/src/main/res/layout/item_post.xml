<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:elevation="2dp"
    android:layout_marginBottom="12dp"
    android:padding="12dp">

    <!-- Header: Foto + Nombre + Ubicación + Tiempo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgUserPhoto"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_profile"
            android:background="@drawable/circle_bg"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/txtUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/txtUbicacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#999999" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textSize="12sp"
                    android:textColor="#999999" />

                <TextView
                    android:id="@+id/txtTiempo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/imgMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_menu_dots"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Categoría (badge) -->
    <TextView
        android:id="@+id/txtCategoria"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:background="@drawable/category_unselected"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:gravity="center"
        android:textSize="12sp"
        android:textColor="#0A7A33"
        android:layout_marginTop="8dp" />

    <!-- Título -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#0A7A33"
        android:layout_marginTop="10dp" />

    <!-- Contenido -->
    <TextView
        android:id="@+id/txtContenido"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="#555555"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="4dp" />

    <!-- Contenedor de imágenes - ESTILO X (TWITTER) -->
    <HorizontalScrollView
        android:id="@+id/imagenesContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/imagenesLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="0dp" />

    </HorizontalScrollView>

    <!-- Botones de acción: Like, Comentar, Compartir -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/layoutLike"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp">

            <ImageView
                android:id="@+id/imgLike"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_like" />

            <TextView
                android:id="@+id/txtLikes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutComment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_comment" />

            <TextView
                android:id="@+id/txtComments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_share" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Compartir"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Línea divisoria antes de comentarios -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="8dp" />

    <!-- Contenedor de comentarios -->
    <LinearLayout
        android:id="@+id/commentsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:paddingTop="8dp"
        android:visibility="gone" />

    <!-- Botón "Ver más comentarios" -->
    <TextView
        android:id="@+id/txtVerMasComentarios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ver más comentarios"
        android:textSize="13sp"
        android:textColor="#0A7A33"
        android:layout_marginTop="4dp"
        android:padding="4dp"
        android:visibility="gone"
        android:background="?attr/selectableItemBackground" />

    <!-- Input para escribir comentario -->
    <LinearLayout
        android:id="@+id/commentInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/edtNuevoComentario"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Escribe un comentario..."
            android:background="@drawable/edittext_style"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnEnviarComentario"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Enviar"
            android:textSize="12sp"
            android:backgroundTint="#0A7A33"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>