<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Header -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_header_gradient">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛍️ MI TIENDA"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Administra tus productos fácilmente"
                android:textSize="13sp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:alpha="0.85"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Barra de búsqueda -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <EditText
                android:id="@+id/etBuscar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="🔍 Buscar producto..."
                android:padding="12dp"
                android:background="@android:drawable/editbox_background"
                android:textColor="@android:color/black"/>

            <Button
                android:id="@+id/btnBuscar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Buscar"
                android:textColor="@android:color/white"
                android:backgroundTint="#4CAF50"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Botones principales (AHORA CON 3 BOTONES) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnAgregar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="➕ Agregar"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"/>

        <Button
            android:id="@+id/btnVerTodos"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="📋 Ver Todos"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:backgroundTint="#2196F3"/>

        <!-- NUEVO BOTÓN WEBSERVICES -->
        <Button
            android:id="@+id/btnWebServices"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="🌐 WebServices"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:backgroundTint="#FF9800"/>

    </LinearLayout>

    <!-- Título de la lista -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📦 Mis Productos"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#202124"/>

        <TextView
            android:id="@+id/tvCantidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 productos"
            android:textSize="12sp"
            android:textColor="#9AA0A6"/>

    </LinearLayout>

    <!-- Lista de productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProductos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"/>

</LinearLayout>